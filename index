<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>תכנית העבודה 2026 | עיריית גני תקווה</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@400;500;700;900&family=Heebo:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --paper:#F1F3EA;
  --paper-raised:#FAFAF3;
  --ink:#1E2A22;
  --ink-soft:#4B5B4F;
  --line:#D9DCC9;
  --green:#3F6B4C;
  --green-deep:#26402F;
  --gold:#C08829;
  --gold-soft:#E9D8AE;
  --brick:#A24B36;
  --gray:#8A8A78;
  --card-shadow: 0 1px 2px rgba(30,42,34,0.06), 0 4px 14px rgba(30,42,34,0.05);
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  margin:0;
  background:var(--paper);
  color:var(--ink);
  font-family:'Heebo',sans-serif;
  font-weight:400;
  line-height:1.6;
}
h1,h2,h3,h4{
  font-family:'Frank Ruhl Libre',serif;
  margin:0;
  color:var(--green-deep);
}
.mono{font-family:'IBM Plex Mono',monospace; direction:ltr; unicode-bidi:embed;}
a{color:inherit;}
.wrap{max-width:1180px; margin:0 auto; padding:0 24px;}

/* ---------- HERO ---------- */
.hero{
  background:linear-gradient(180deg,var(--green-deep) 0%, var(--green) 100%);
  color:#EFEFE2;
  padding:64px 0 40px;
  position:relative;
  overflow:hidden;
}
.hero::after{
  content:"";
  position:absolute; inset:0;
  background-image: radial-gradient(circle at 18% 30%, rgba(255,255,255,0.05) 0, transparent 45%),
                     radial-gradient(circle at 85% 75%, rgba(192,136,41,0.15) 0, transparent 50%);
  pointer-events:none;
}
.hero-inner{position:relative; z-index:1;}
.eyebrow{
  font-family:'IBM Plex Mono',monospace;
  font-size:12.5px; letter-spacing:.12em; text-transform:uppercase;
  color:var(--gold-soft); margin-bottom:14px; direction:ltr; text-align:right; unicode-bidi:plaintext;
}
.hero h1{
  color:#fff; font-size:clamp(34px,5vw,58px); font-weight:700; letter-spacing:-0.01em;
  margin-bottom:10px;
}
.hero p.lead{
  max-width:640px; color:#DDE3D2; font-size:17px; font-weight:300; margin-bottom:36px;
}
.stat-row{display:flex; flex-wrap:wrap; gap:14px;}
.stat-seal{
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.14);
  border-radius:14px;
  padding:16px 22px;
  min-width:140px;
}
.stat-seal .num{
  font-family:'Frank Ruhl Libre',serif; font-size:30px; color:#fff; font-weight:700; line-height:1;
}
.stat-seal .lbl{font-size:12.5px; color:var(--gold-soft); margin-top:6px;}

/* ---------- PILLARS ---------- */
.pillars{
  background:var(--paper-raised);
  border-bottom:1px solid var(--line);
  padding:26px 0;
}
.pillars-scroll{display:flex; gap:10px; overflow-x:auto; padding-bottom:4px;}
.pillar-chip{
  flex:0 0 auto;
  display:flex; align-items:center; gap:10px;
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:999px;
  padding:9px 16px 9px 10px;
  cursor:pointer;
  transition:all .15s ease;
  white-space:nowrap;
  font-size:14px;
}
.pillar-chip:hover{border-color:var(--green);}
.pillar-chip.active{background:var(--green); color:#fff; border-color:var(--green);}
.pillar-chip .n{
  font-family:'IBM Plex Mono',monospace;
  background:var(--gold); color:#fff;
  width:20px; height:20px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:11px;
}
.pillar-chip.active .n{background:#fff; color:var(--green-deep);}

/* ---------- CONTROLS ---------- */
.controls{
  position:sticky; top:0; z-index:20;
  background:var(--paper); border-bottom:1px solid var(--line);
  padding:16px 0;
}
.controls-inner{display:flex; flex-wrap:wrap; gap:10px; align-items:center;}
.search-box{
  flex:1 1 240px;
  display:flex; align-items:center; gap:8px;
  background:var(--paper-raised); border:1px solid var(--line); border-radius:10px;
  padding:10px 14px;
}
.search-box input{
  border:none; background:transparent; outline:none; width:100%;
  font-family:'Heebo',sans-serif; font-size:14.5px; color:var(--ink);
}
select{
  font-family:'Heebo',sans-serif; font-size:14px; color:var(--ink);
  background:var(--paper-raised); border:1px solid var(--line); border-radius:10px;
  padding:10px 12px; cursor:pointer; outline:none;
}
.view-toggle{display:flex; background:var(--paper-raised); border:1px solid var(--line); border-radius:10px; overflow:hidden;}
.view-toggle button{
  border:none; background:transparent; padding:10px 18px; font-family:'Heebo',sans-serif;
  font-size:14px; cursor:pointer; color:var(--ink-soft);
}
.view-toggle button.active{background:var(--green); color:#fff;}
.result-count{font-size:13px; color:var(--ink-soft); padding:0 4px;}

/* ---------- DEPARTMENTS ---------- */
.content{padding:32px 0 80px;}
.dept{
  margin-bottom:14px;
  background:var(--paper-raised);
  border:1px solid var(--line);
  border-radius:16px;
  overflow:hidden;
}
.dept-head{
  display:flex; align-items:center; justify-content:space-between;
  padding:18px 22px; cursor:pointer; gap:16px;
}
.dept-head:hover{background:rgba(63,107,76,0.04);}
.dept-head h3{font-size:21px; color:var(--green-deep);}
.dept-meta{display:flex; align-items:center; gap:16px;}
.dept-count{font-size:13px; color:var(--ink-soft); font-family:'IBM Plex Mono',monospace;}
.ring{width:34px; height:34px;}
.chevron{transition:transform .2s ease; color:var(--gray);}
.dept.open .chevron{transform:rotate(180deg);}
.dept-body{
  display:none;
  padding:4px 22px 22px;
  border-top:1px solid var(--line);
}
.dept.open .dept-body{display:block;}
.card-grid{display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:14px; margin-top:16px;}

.card{
  background:var(--paper); border:1px solid var(--line); border-radius:12px;
  padding:18px; box-shadow:var(--card-shadow);
}
.card .tag{
  display:inline-block; font-size:11.5px; font-family:'IBM Plex Mono',monospace;
  color:var(--green-deep); background:var(--gold-soft);
  border-radius:6px; padding:3px 8px; margin-bottom:10px;
}
.card h4{font-size:16.5px; line-height:1.4; margin-bottom:8px; color:var(--ink);}
.card .task-desc{font-size:13.8px; color:var(--ink-soft); margin-bottom:12px;}
.meta-line{
  display:flex; flex-wrap:wrap; gap:6px 14px; font-size:12.5px; color:var(--ink-soft);
  border-top:1px dashed var(--line); padding-top:10px; margin-top:10px;
}
.meta-line span b{color:var(--ink); font-weight:500;}
.badge{
  display:inline-flex; align-items:center; gap:5px;
  font-size:12px; border-radius:999px; padding:4px 10px; font-weight:500;
}
.badge.done{background:#E1EBE1; color:var(--green-deep);}
.badge.progress{background:#FBEFD6; color:#8A5E11;}
.badge.cancelled{background:#F3DEDA; color:var(--brick);}
.badge.none{background:#EAEAE2; color:var(--gray);}
.badge.update{background:#DCE7EC; color:#2E5468;}
.badge .dot{width:6px; height:6px; border-radius:50%; background:currentColor;}
.status-text{
  font-size:12.8px; color:var(--ink-soft); background:var(--paper-raised);
  border-right:3px solid var(--gold); padding:8px 10px; margin-top:10px; border-radius:0 6px 6px 0;
  white-space:pre-line;
}

.ong-list{margin-top:16px; display:flex; flex-direction:column; gap:10px;}
.ong-item{
  background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:14px 16px;
  display:flex; flex-wrap:wrap; justify-content:space-between; gap:8px;
}
.ong-item .t{font-size:14px; font-weight:500; flex:1 1 260px;}
.ong-item .p{font-size:12.8px; color:var(--ink-soft); flex:1 1 260px;}
.ong-item .b{font-size:12.5px; font-family:'IBM Plex Mono',monospace; color:var(--green-deep); white-space:nowrap;}

.empty-state{text-align:center; padding:60px 20px; color:var(--ink-soft);}
.empty-state h3{color:var(--ink-soft); margin-bottom:8px;}

footer{
  background:var(--green-deep); color:#C8D3C6; padding:30px 0; font-size:13px;
}
footer .wrap{display:flex; flex-wrap:wrap; justify-content:space-between; gap:10px;}

::-webkit-scrollbar{height:6px;}
@media (max-width:640px){
  .hero{padding:44px 0 30px;}
  .controls-inner{flex-direction:column; align-items:stretch;}
}
</style>
</head>
