<script>
const DATA = JSON.parse(document.getElementById('site-data').textContent);
const state = { view:'projects', dept:'', status:'', pillar:'', q:'' };

function ringSVG(pct, size=34){
  const r = (size/2)-4, c = 2*Math.PI*r, off = c*(1-pct);
  return `<svg class="ring" viewBox="0 0 ${size} ${size}">
    <circle cx="${size/2}" cy="${size/2}" r="${r}" fill="none" stroke="#E1E4D5" stroke-width="4"/>
    <circle cx="${size/2}" cy="${size/2}" r="${r}" fill="none" stroke="#C08829" stroke-width="4"
      stroke-dasharray="${c}" stroke-dashoffset="${off}" stroke-linecap="round"
      transform="rotate(-90 ${size/2} ${size/2})"/>
  </svg>`;
}

function renderStats(){
  const s = DATA.stats;
  const items = [
    [s.departments, 'אגפים ומחלקות'],
    [s.projects, 'פרויקטים ויעדים'],
    [s.ongoing, 'משימות שוטפות'],
    [s.budget_total, 'תקציב מצטבר משוער']
  ];
  document.getElementById('statRow').innerHTML = items.map(([num,lbl])=>
    `<div class="stat-seal"><div class="num mono">${num}</div><div class="lbl">${lbl}</div></div>`
  ).join('');
}

function renderPillars(){
  const row = document.getElementById('pillarsRow');
  let html = `<div class="pillar-chip active" data-id="">
      <span class="n">•</span> כל מטרות-העל
    </div>`;
  html += DATA.pillars.map(p=>
    `<div class="pillar-chip" data-id="${p.id}" title="${p.desc}">
      <span class="n">${p.n}</span> ${p.title}
    </div>`
  ).join('');
  row.innerHTML = html;
  row.querySelectorAll('.pillar-chip').forEach(chip=>{
    chip.addEventListener('click', ()=>{
      row.querySelectorAll('.pillar-chip').forEach(c=>c.classList.remove('active'));
      chip.classList.add('active');
      state.pillar = chip.dataset.id;
      render();
    });
  });
}

function renderDeptSelect(){
  const sel = document.getElementById('deptSelect');
  sel.innerHTML = `<option value="">כל האגפים</option>` +
    DATA.departments.map(d=>`<option value="${d.name}">${d.name}</option>`).join('');
}

function matchProject(p, dept){
  if(state.pillar && p.goal_short !== state.pillar) return false;
  if(state.status && p.status_key !== state.status) return false;
  if(state.q){
    const hay = [dept.name,p.goal,p.objective,p.task,p.responsible,p.partners,p.success_metrics].join(' ').toLowerCase();
    if(!hay.includes(state.q)) return false;
  }
  return true;
}
function matchOngoing(o, dept){
  if(state.status) return false; // status filter not applicable to ongoing
  if(state.pillar) return false; // pillar filter not applicable to ongoing
  if(state.q){
    const hay = [dept.name,o.task,o.purpose,o.measurement].join(' ').toLowerCase();
    if(!hay.includes(state.q)) return false;
  }
  return true;
}

function projectCard(p){
  return `<div class="card">
    <span class="tag">${p.goal_short}</span>
    <h4>${p.objective || p.task}</h4>
    ${p.objective ? `<div class="task-desc">${p.task||''}</div>` : ''}
    <div class="meta-line">
      ${p.responsible ? `<span>אחראי: <b>${p.responsible}</b></span>` : ''}
      ${p.partners ? `<span>שותפים: <b>${p.partners}</b></span>` : ''}
      ${(p.start_date||p.end_date) ? `<span>לו״ז: <b class="mono">${p.start_date||'—'} → ${p.end_date||'—'}</b></span>` : ''}
      ${p.budget ? `<span>תקציב: <b class="mono">${p.budget}</b></span>` : ''}
    </div>
    ${p.success_metrics ? `<div class="meta-line" style="border-top:none; margin-top:4px; padding-top:0;"><span>מדד הצלחה: ${p.success_metrics}</span></div>` : ''}
    <div class="badge ${p.status_key}"><span class="dot"></span>${p.status_label}</div>
    ${p.status_text ? `<div class="status-text">${p.status_text}</div>` : ''}
  </div>`;
}

function ongoingItem(o){
  return `<div class="ong-item">
    <div class="t">${o.task}</div>
    <div class="p">${o.purpose||''}</div>
    ${o.budget ? `<div class="b">${o.budget}</div>` : ''}
  </div>`;
}

function render(){
  const container = document.getElementById('deptContainer');
  let totalShown = 0;
  let html = '';
  DATA.departments.forEach(d=>{
    if(state.dept && d.name !== state.dept) return;
    let bodyHtml = '';
    let count = 0;
    if(state.view === 'projects'){
      const items = d.projects.filter(p=>matchProject(p,d));
      count = items.length;
      if(count === 0) return;
      const doneCount = d.projects.filter(p=>p.status_key==='done').length;
      const pct = d.projects.length ? doneCount/d.projects.length : 0;
      bodyHtml = `<div class="card-grid">${items.map(projectCard).join('')}</div>`;
      html += deptBlock(d, count, bodyHtml, pct);
    } else {
      const items = d.ongoing.filter(o=>matchOngoing(o,d));
      count = items.length;
      if(count === 0) return;
      bodyHtml = `<div class="ong-list">${items.map(ongoingItem).join('')}</div>`;
      html += deptBlock(d, count, bodyHtml, null);
    }
    totalShown += count;
  });

  document.getElementById('resultCount').textContent =
    totalShown ? `מוצגים ${totalShown} פריטים` : '';

  container.innerHTML = html || `<div class="empty-state"><h3>לא נמצאו תוצאות</h3><div>נסו לשנות את מונחי החיפוש או המסננים</div></div>`;

  container.querySelectorAll('.dept-head').forEach(h=>{
    h.addEventListener('click', ()=> h.parentElement.classList.toggle('open'));
  });

  // auto-open if a single department is selected or a search is active
  if(state.dept || state.q || state.pillar || state.status){
    container.querySelectorAll('.dept').forEach(el=>el.classList.add('open'));
  }
}

function deptBlock(d, count, bodyHtml, pct){
  const ring = pct !== null ? ringSVG(pct) : '';
  return `<div class="dept">
    <div class="dept-head">
      <h3>${d.name}</h3>
      <div class="dept-meta">
        <span class="dept-count">${count} פריטים</span>
        ${ring}
        <svg class="chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </div>
    <div class="dept-body">${bodyHtml}</div>
  </div>`;
}

document.getElementById('searchInput').addEventListener('input', e=>{
  state.q = e.target.value.trim().toLowerCase();
  render();
});
document.getElementById('deptSelect').addEventListener('change', e=>{
  state.dept = e.target.value; render();
});
document.getElementById('statusSelect').addEventListener('change', e=>{
  state.status = e.target.value; render();
});
document.querySelectorAll('.view-toggle button').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('.view-toggle button').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    state.view = btn.dataset.view;
    render();
  });
});

renderStats();
renderPillars();
renderDeptSelect();
render();
</script>
